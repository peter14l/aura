import { AuraTheme } from "tokens.slint";

export component StatusBar {
    in property <bool> show: false;
    in property <string> status-text: "Breathe in...";
    callback lotus-clicked();

    opacity: show ? 1.0 : 0.0;
    y: show ? parent.height - self.height : parent.height;
    animate opacity, y { duration: 300ms; easing: AuraTheme.ease-breathe; }

    x: 0;
    width: 100%;
    height: 40px;

    Rectangle {
        background: AuraTheme.glass;
        
        HorizontalLayout {
            padding-left: 20px;
            padding-right: 20px;
            spacing: 12px;

            Text {
                text: status-text;
                color: AuraTheme.base;
                font-size: 11px;
                vertical-alignment: center;
            }

            Rectangle {} // Spacer

            // Lotus AI Icon
            TouchArea {
                width: 32px;
                height: 32px;
                clicked => { root.lotus-clicked(); }
                
                Rectangle {
                    width: 20px;
                    height: 20px;
                    border-radius: 10px;
                    background: AuraTheme.rose;
                    opacity: 0.6;
                    
                    // Simple "lotus" shape approximation
                    Rectangle {
                        width: 14px; height: 14px;
                        border-radius: 7px;
                        background: AuraTheme.rose;
                        x: 3px; y: 3px;
                    }
                    Rectangle {
                        width: 10px; height: 10px;
                        border-radius: 5px;
                        background: AuraTheme.obsidian;
                        x: 5px; y: 5px;
                        opacity: 0.3;
                    }
                }
            }
        }
    }
}
