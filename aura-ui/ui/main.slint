import { AuraTheme } from "tokens.slint";
import { CommandBar } from "command-bar.slint";
import { Constellation, TabNode } from "constellation.slint";
import { BreatheOverlay } from "breathe-overlay.slint";
import { AddressGhost } from "address-ghost.slint";
import { StatusBar } from "status-bar.slint";

export component MainUI inherits Window {
    in property <bool> command-bar-visible: false;
    in property <bool> constellation-visible: false;
    in property <bool> breathe-visible: false;
    in property <bool> address-ghost-visible: false;
    in property <bool> status-bar-visible: false;
    
    in property <string> active-url: "aura://home";
    in property <string> status-message: "Ready";
    in property <[TabNode]> tabs;
    in property <[string]> breathe-bullets;
    
    callback navigate(string);
    callback tab-selected(int);
    callback lotus-clicked();
    callback mouse-event(float, float, int); // x, y, type (0=move, 1=down, 2=up)
    callback key-event(string, string, int, int, bool); // key, code, state, modifiers, repeat

    background: transparent;

    FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            root.key-event(event.text, "", 0, 0, event.repeat);
            accept
        }
        key-released(event) => {
            root.key-event(event.text, "", 1, 0, false);
            accept
        }

        TouchArea {
            width: 100%;
            height: 100%;
            pointer-event(event) => {
                if (event.button == PointerEventButton.left) {
                    if (event.kind == PointerEventKind.down) {
                        root.mouse-event(self.mouse-x / 1px, self.mouse-y / 1px, 1);
                    } else if (event.kind == PointerEventKind.up) {
                        root.mouse-event(self.mouse-x / 1px, self.mouse-y / 1px, 2);
                    }
                }
            }
            moved => {
                root.mouse-event(self.mouse-x / 1px, self.mouse-y / 1px, 0);
            }
        }
    }

    AddressGhost {
        show: address-ghost-visible;
        url: active-url;
        x: (parent.width - self.width) / 2;
        width: min(parent.width * 40%, 400px);
    }

    CommandBar {
        show: command-bar-visible;
        x: (parent.width - self.width) / 2;
        y: parent.height * 32%;
        width: min(parent.width * 55%, 680px);
        height: 52px;
        submitted(url) => { root.navigate(url); }
    }

    Constellation {
        show: constellation-visible;
        tabs: tabs;
        tab-selected(i) => { root.tab-selected(i); }
    }

    BreatheOverlay {
        show: breathe-visible;
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 24px;
        width: min(parent.width * 60%, 520px);
        height: 160px;
        bullets: breathe-bullets;
    }

    StatusBar {
        show: status-bar-visible;
        status-text: status-message;
        y: self.show ? parent.height - self.height : parent.height;
        animate y { duration: 300ms; easing: AuraTheme.ease-breathe; }
        lotus-clicked => { root.lotus-clicked(); }
    }
}
