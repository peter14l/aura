import { AuraTheme } from "tokens.slint";

export component AddressGhost {
    in property <bool> visible: false;
    in property <string> url: "aura://newtab";
    
    opacity: visible ? 0.8 : 0.0;
    y: visible ? 0px : -20px;
    animate opacity, y { duration: 300ms; easing: AuraTheme.ease-breathe; }

    x: (parent.width - self.width) / 2;
    width: min(parent.width * 0.4, 400px);
    height: 32px;

    Rectangle {
        background: AuraTheme.glass;
        border-bottom-left-radius: 12px;
        border-bottom-right-radius: 12px;

        Text {
            text: url;
            color: AuraTheme.base;
            font-size: 12px;
            font-italic: true;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}
