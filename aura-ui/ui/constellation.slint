import { AuraTheme } from "tokens.slint";

export struct TabNode {
    id: int,
    title: string,
    favicon: image,
    glow_color: color,
    active: bool,
    pinned: bool,
}

export component TabOrb {
    in property <TabNode> node;
    callback clicked();
    callback closed();

    width: node.active ? 48px : 36px;
    height: self.width;
    animate width, height { duration: 250ms; easing: AuraTheme.ease-breathe; }

    Rectangle {
        border-radius: self.width / 2;
        background: node.glow_color.with-alpha(0.3);
        border-width: node.active ? 2px : 0px;
        border-color: node.glow_color;
        
        drop-shadow-blur: node.active ? 20px : 8px;
        drop-shadow-color: node.glow_color.with-alpha(0.5);

        Image { 
            source: node.favicon; 
            width: 50%; 
            height: 50%; 
            opacity: 0.8;
        }

        TouchArea {
            clicked => { root.clicked(); }
            // Long press or right click could trigger closed()
        }
    }
}

export component Constellation {
    in property <[TabNode]> tabs;
    in property <bool> show: false;
    callback tab-selected(int);

    x: show ? 0px : -100px;
    opacity: show ? 1.0 : 0.0;
    animate x, opacity { duration: 400ms; easing: AuraTheme.ease-breathe; }

    width: 100px;
    height: 100%;

    Rectangle {
        background: AuraTheme.glass;
        
        VerticalLayout {
            padding: 24px;
            spacing: 20px;
            alignment: center;

            for tab[i] in tabs : TabOrb {
                node: tab;
                clicked => { root.tab-selected(tab.id); }
            }
        }
    }
}
