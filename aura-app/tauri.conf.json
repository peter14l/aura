{
  "productName": "Aura",
  "version": "0.1.0",
  "identifier": "dev.aura-browser.app",
  "build": {
    "frontendDist": "public"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [{
      "label": "main",
      "title": "Aura",
      "decorations": false,
      "transparent": true,
      "resizable": true,
      "width": 1200,
      "height": 800,
      "minWidth": 400,
      "minHeight": 300
    }]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
